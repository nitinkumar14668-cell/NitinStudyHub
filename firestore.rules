rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'nitinkumar14668@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Note
    function isValidNote(data) {
      return data.keys().hasAll(['title', 'price', 'pdfUrl']) &&
             data.title is string && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.pdfUrl is string && data.pdfUrl.size() <= 1000;
    }

    // Validation Blueprint for Transaction
    function isValidTransaction(data) {
      return data.keys().hasAll(['noteId', 'amount', 'status', 'userId', 'createdAt']) &&
             data.noteId is string && data.noteId.size() <= 128 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'verifying', 'approved', 'rejected'] &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // Notes Collection
    match /notes/{noteId} {
      allow read: if true; // Public catalog
      allow create, update, delete: if isAdmin() && isValidNote(incoming());
    }

    // Transactions Collection
    match /transactions/{transactionId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidTransaction(incoming()) && 
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
      
      allow update: if (isOwner(existing().userId) || isAdmin()) && (
        // Action: Upload Screenshot & Set Verifying
        (incoming().diff(existing()).affectedKeys().hasOnly(['screenshotUrl', 'status', 'updatedAt']) &&
         incoming().status == 'verifying' &&
         incoming().screenshotUrl is string &&
         incoming().updatedAt == request.time) ||
        
        // Action: Admin Approve/Reject (or simulated for demo)
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'downloadToken', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||

        // Action: Demo Self-Verification (Owner can approve for demo flow)
        (isOwner(existing().userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'downloadToken', 'updatedAt', 'downloaded']) &&
         existing().status == 'verifying' &&
         incoming().status == 'approved' &&
         incoming().downloadToken is string &&
         incoming().downloaded == false &&
         incoming().updatedAt == request.time) ||

        // Action: Mark as Downloaded (One-time check)
        (isOwner(existing().userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['downloaded', 'updatedAt']) &&
         existing().status == 'approved' &&
         existing().downloaded == false &&
         incoming().downloaded == true &&
         incoming().updatedAt == request.time)
      );
    }
  }
}
